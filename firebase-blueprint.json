{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences and onboarding data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "incomeBracket": { "type": "string" },
        "goals": { "type": "array", "items": { "type": "string" } },
        "preferredLanguage": { "type": "string" },
        "isZeroRetention": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "A single financial transaction parsed from a statement.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "bank": { "type": "string" },
        "rawDescription": { "type": "string" }
      },
      "required": ["userId", "date", "amount", "type"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transactions for a specific user."
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Chat history for a specific user."
    }
  }
}
